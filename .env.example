# MailExplorer Production Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Superadmin password (change this!)
SUPERADMIN_PASSWORD=your-strong-admin-password

# CORS origins (comma-separated list of allowed domains)
# Include your Railway frontend URL here
CORS_ORIGINS=https://your-frontend.up.railway.app

# Redis URL (provided by Railway Redis addon)
# REDIS_URL=redis://default:password@redis.railway.internal:6379
